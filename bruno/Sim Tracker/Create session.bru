meta {
  name: Create session
  type: http
  seq: 1
}

post {
  url: http://localhost:8000/api/1/session
  body: json
  auth: inherit
}

body:json {
  {
    "car": "Porsche",
    "track": "track1",
    "simulator": "ACC",
    "sessionType": "practice"
  }
}

script:post-response {
    bru.setVar("sessionUid", res.body.uid)
  
}

settings {
  encodeUrl: true
}
