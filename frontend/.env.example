# Feedback form → Google Form integration (frontend only).
#
# Copy to `.env.local` and fill in to enable the in-dashboard Feedback launcher.
# When VITE_FEEDBACK_FORM_URL (or the required entry ids) is unset, the launcher
# is hidden and no feedback UI renders.
#
# Find the values by opening your Google Form's pre-filled link / page source:
#  - FORM_URL is the form action ending in `/formResponse`
#    e.g. https://docs.google.com/forms/d/e/<form-id>/formResponse
#  - each ENTRY_* is the `entry.<numeric-id>` field name for that question.

# Required: the form endpoint plus the type and message questions.
VITE_FEEDBACK_FORM_URL=
VITE_FEEDBACK_ENTRY_TYPE=
VITE_FEEDBACK_ENTRY_MESSAGE=

# Optional: omit an id to drop that field from the submission.
VITE_FEEDBACK_ENTRY_EMAIL=
VITE_FEEDBACK_ENTRY_VERSION=
VITE_FEEDBACK_ENTRY_SCREEN=
